{% comment %}
  DataTables-based equivalent of artifacts.xml.
  Drop {% include artifacts-table.xml %} into a page (e.g. artifacts-table.md) — one such page per language folder.
  Picks the right translation per row at Jekyll time, falling back to the IG's source-language string when missing.
{% endcomment %}
{% assign lang = page.path | split: "/" | first %}
{% assign groupingStrings = site.data.stringsArtifacts[lang] %}
{% if groupingStrings == nil %}{% assign groupingStrings = site.data.stringsArtifacts.en %}{% endif %}

<link rel="stylesheet" href="assets/css/dataTables.min.css"/>
<link rel="stylesheet" href="assets/css/dataTables.rowGroup.min.css"/>
<style>
  /* Group header — neutral overlay, no theme color */
  #artifactsTable tr.dtrg-group td.artifacts-group-header {
    background:rgba(0,0,0,0.08);
    border-top:1px solid rgba(0,0,0,0.15);
    border-bottom:1px solid rgba(0,0,0,0.15);
    padding:.6em .9em;
  }
  #artifactsTable .artifacts-group-name { font-weight:700; font-size:1.1em; }
  #artifactsTable .artifacts-group-desc { font-weight:normal; font-size:.92em; margin-top:.3em; opacity:.75; }
  #artifactsTable .artifacts-group-desc p:last-child { margin-bottom:0; }

  /* Body markdown spacing */
  #artifactsTable tbody td p { margin:0 0 .25em 0; }
  #artifactsTable tbody td p:last-child { margin-bottom:0; }

  /* Per-column filter row */
  #artifactsTable thead tr.filters th { padding:.25em .5em; background:rgba(0,0,0,0.03); }
  #artifactsTable thead tr.filters input { width:100%; box-sizing:border-box; padding:.25em .5em; border:1px solid rgba(0,0,0,0.2); border-radius:3px; font-weight:normal; font-size:.9em; background:#fff; }
  #artifactsTable thead tr.filters th.sorting,
  #artifactsTable thead tr.filters th.sorting_asc,
  #artifactsTable thead tr.filters th.sorting_desc { background-image:none !important; cursor:default; }

  /* Grouping toggle — sits inside DataTables top control row, looks like a checkbox */
  .dt-grouping-toggle {
    display:inline-flex;
    align-items:center;
    gap:.4em;
    margin:0 2em;
    font-size:.9em;
    cursor:pointer;
    user-select:none;
    opacity:.85;
  }
  .dt-grouping-toggle input { margin:0; cursor:pointer; }
  .dt-grouping-toggle:hover { opacity:1; }

  /* Intro paragraph above the table */
  .artifacts-table-intro { margin:.25em 0 1em 0; }

  /* Top/bottom controls — neutral, no theme color */
  .dt-container .dt-layout-row { padding:.4em 0; align-items:center; }
  .dt-container .dt-search input,
  .dt-container .dt-length select {
    padding:.3em .5em;
    border:1px solid rgba(0,0,0,0.2);
    border-radius:3px;
    background:#fff;
    font-size:.9em;
  }
  .dt-container .dt-search label,
  .dt-container .dt-length label { font-weight:normal; opacity:.75; }
  .dt-container .dt-info { opacity:.75; font-size:.9em; }
  .dt-container .dt-paging .dt-paging-button {
    border:1px solid rgba(0,0,0,0.2) !important;
    background:#fff !important;
    padding:.25em .65em !important;
    margin:0 2px !important;
    border-radius:3px !important;
    font-size:.9em !important;
    cursor:pointer;
  }
  .dt-container .dt-paging .dt-paging-button.current,
  .dt-container .dt-paging .dt-paging-button.current:hover {
    background:rgba(0,0,0,0.12) !important;
    border-color:rgba(0,0,0,0.3) !important;
    font-weight:bold;
  }
  .dt-container .dt-paging .dt-paging-button:hover:not(.current):not(.disabled) {
    background:rgba(0,0,0,0.05) !important;
  }
  .dt-container .dt-paging .dt-paging-button.disabled,
  .dt-container .dt-paging .dt-paging-button.disabled:hover {
    opacity:.4;
    cursor:default;
    background:#fff !important;
  }
</style>

{%- assign nameLabel = site.data.stringsBase[lang]['Name'] | default: 'Name' -%}
{%- assign typeLabel = site.data.stringsBase[lang]['Type'] | default: 'Type' -%}
{%- assign descLabel = site.data.stringsBase[lang]['Description'] | default: 'Description' -%}
{%- assign searchVerb = site.data.stringsBase[lang]['Search'] | default: 'Search' -%}

{%- assign useGroupingLabel = site.data.stringsBase[lang]['UseGrouping'] | default: 'Use grouping' -%}

<p class="artifacts-table-intro">{{ site.data.stringsBase[lang]['ArtifactsTableIntro'] | default: 'This page provides a tabular view of the FHIR artifacts defined as part of this implementation guide.' }}</p>

<table id="artifactsTable" class="display" style="width:100%" data-fhir="generated">
  <thead>
    <tr>
      <th></th>
      <th>{{ site.data.stringsBase[lang]['Grouping'] | default: 'Grouping' }}</th>
      <th>{{ nameLabel }}</th>
      <th>{{ typeLabel }}</th>
      <th>{{ descLabel }}</th>
    </tr>
    <tr class="filters">
      <th></th>
      <th></th>
      <th><input type="text" placeholder="{{ searchVerb }} {{ nameLabel | downcase }}"/></th>
      <th><input type="text" placeholder="{{ searchVerb }} {{ typeLabel | downcase }}"/></th>
      <th><input type="text" placeholder="{{ searchVerb }} {{ descLabel | downcase }}"/></th>
    </tr>
  </thead>
</table>

<script defer src="assets/js/dataTables.min.js"></script>
<script defer src="assets/js/dataTables.rowGroup.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function(){
  var data = [
{%- for r in site.data.artifactsTable -%}
{%- assign nm = r.name[lang] | default: r.name.src -%}
{%- assign descRaw = r.description[lang] | default: r.description.src | default: '' -%}
{%- assign desc = descRaw | markdownify | strip -%}
{%- assign gKey = r.groupingName | append: 'Name' -%}
{%- assign groupLabel = groupingStrings[gKey] | default: r.groupingName -%}
    { "p":{{ r.groupingPos }}, "gid":{{ r.groupingId | jsonify }}, "g":{{ groupLabel | jsonify }}, "n":{{ nm | jsonify }}, "t":{{ r.type | jsonify }}, "u":{{ r.url | jsonify }}, "r":{{ r.ref | jsonify }}, "d":{{ desc | jsonify }} }{%- unless forloop.last -%},{%- endunless %}
{%- endfor %}
  ];

  var groupDescriptions = {};
{%- assign seenGids = "|" -%}
{%- for r in site.data.artifactsTable -%}
{%- assign marker = r.groupingId | prepend: "|" | append: "|" -%}
{%- unless seenGids contains marker -%}
{%- assign seenGids = seenGids | append: r.groupingId | append: "|" -%}
{%- assign descKey = r.groupingName | append: 'Desc' -%}
{%- assign descMd = groupingStrings[descKey] -%}
{%- if descMd == nil or descMd == '' -%}
  {%- assign descMd = r.groupingDescription[lang] | default: r.groupingDescription.src -%}
{%- endif -%}
{%- if descMd and descMd != '' %}
  groupDescriptions[{{ r.groupingId | jsonify }}] = {{ descMd | markdownify | jsonify }};
{%- endif -%}
{%- endunless -%}
{%- endfor %}

  function escapeHtml(s){ return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
  }); }

  function htmlToText(s){ return jQuery('<div/>').html(s || '').text(); }

  var useGroupingLabel = {{ useGroupingLabel | jsonify }};
  var grouping = true;

  // Register a custom DataTables feature for the grouping checkbox
  if (!jQuery.fn.dataTable.feature.__artifactsGroupRegistered) {
    jQuery.fn.dataTable.feature.__artifactsGroupRegistered = true;
    jQuery.fn.dataTable.feature.register('artifactsGroupToggle', function(){
      var label = document.createElement('label');
      label.className = 'dt-grouping-toggle';
      var cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.id = 'artifactsGroupToggle';
      cb.checked = grouping;
      var span = document.createElement('span');
      span.textContent = useGroupingLabel;
      label.appendChild(cb);
      label.appendChild(span);
      return label;
    });
  }

  function buildConfig(grouping){
    var cfg = {
      orderCellsTop: true,
      layout: {
        topStart: ['search', 'artifactsGroupToggle'],
        topEnd: ['paging', 'pageLength'],
        bottomStart: 'info',
        bottomEnd: 'paging'
      },
      data: data,
      columns: [
        { data: 'p', visible: false, searchable: false },
        { data: 'g', visible: false },
        { data: 'n', render: function(d, t, row){
            if (t === 'display') {
              return '<a href="' + encodeURI(row.u) + '" title="' + escapeHtml(row.r) + '">' + escapeHtml(d) + '</a>';
            }
            return d;
          }
        },
        { data: 't' },
        { data: 'd', render: function(d, t){
            if (t === 'display') return d;
            return htmlToText(d);
          }
        }
      ],
      order: grouping ? [[0, 'asc']] : [[2, 'asc']],
      pageLength: 200,
      lengthMenu: [[10, 25, 50, 100, 200, 500, 1000], [10, 25, 50, 100, 200, 500, 1000]]
    };
    if (grouping) {
      cfg.orderFixed = [[0, 'asc']];
      cfg.rowGroup = {
        dataSrc: 'g',
        startRender: function(rows, group){
          var first = rows.data().toArray()[0];
          var desc = first && groupDescriptions[first.gid];
          var $header = jQuery('<tr/>').append(
            jQuery('<td/>').attr('colspan', 3).addClass('artifacts-group-header')
          );
          var $cell = $header.find('td');
          jQuery('<div/>').addClass('artifacts-group-name').text(group).appendTo($cell);
          if (desc) {
            jQuery('<div/>').addClass('artifacts-group-desc').html(desc).appendTo($cell);
          }
          return $header;
        }
      };
    }
    return cfg;
  }

  var table;
  function renderTable(grouping){
    if (table) table.destroy();
    table = jQuery('#artifactsTable').DataTable(buildConfig(grouping));
    jQuery('#artifactsTable thead tr.filters input').off('.artifactsFilter').on('keyup.artifactsFilter change.artifactsFilter clear.artifactsFilter', function(){
      var idx = jQuery(this).closest('th').index();
      var col = table.column(idx);
      if (col.search() !== this.value) col.search(this.value).draw();
    }).on('click.artifactsFilter', function(e){ e.stopPropagation(); });
  }

  renderTable(grouping);

  // Document-delegated handler — survives table rebuild (which destroys the checkbox DOM)
  jQuery(document).on('change', '#artifactsGroupToggle', function(){
    grouping = this.checked;
    renderTable(grouping);
  });
});
</script>
